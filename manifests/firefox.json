{
  "manifest_version": 3,
  "name": "ChatTrail",
  "version": "1.0.0",
  "description": "Navigate your AI chats prompts in a lightweight sidebar.",
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "chattrail@example.com",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}